# 閲覧系フロント（web/）が使う公開設定。実キーはコミットしない（docs/02 セキュリティ）。
# Phase1 は FixtureProvider 動作のため未設定でも起動する。
# SupabaseProvider を有効化する際にのみ必要。

# フレームデータの供給元: fixture | supabase（未指定なら実データ→フィクスチャの順で自動選択）
VITE_DATA_PROVIDER=fixture

# メモ機能の供給元: mock | supabase（未指定時は VITE_DATA_PROVIDER=supabase なら supabase、それ以外 mock）
# 開発・ブラウザ検証は mock（localStorage 永続）。実 DB 検証時に supabase へ。
VITE_NOTES_PROVIDER=mock

# 実 Supabase 接続情報（supabase プロバイダ選択時に必須）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
